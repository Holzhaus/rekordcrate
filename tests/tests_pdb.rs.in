#[test]
#[allow(non_snake_case)]
fn pdb_{name}() {{
    println!("Parsing file: {filepath}");
    let data = include_bytes!("{filepath}").as_slice();
    let mut reader = Cursor::new(data);
    let mut db = Database::open_non_persistent(&mut reader, DatabaseType::Plain).expect("failed to open database");
    println!("{{:#?}}", db.get_header());

    let table_ids = db.get_header().tables.iter().enumerate().map(|(i, _)| i).collect::<Vec<_>>();
    for i in table_ids {{
        println!("Table {{}}: {{:?}}", i, db.get_header().tables[i].page_type);
        let page_ids = db.load_pages_for_table(i).expect("failed to read pages");

        for page_id in page_ids {{
            let page = db.load_page(page_id).expect("failed to load page");
            println!("  {{:?}}", page);
        }}
    }}
}}
